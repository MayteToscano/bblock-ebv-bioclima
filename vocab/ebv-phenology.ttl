@prefix ebv: <https://maytetoscano.github.io/bblock-ebv-bioclima/vocab/#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ebv: a owl:Ontology ;
  dcterms:title "EBV Phenology Vocabulary"@en , "Vocabulario de fenología EBV"@es ;
  dcterms:description "Temporary GitHub Pages vocabulary for EBV phenology feature-view terms."@en .

ebv:entity_type a owl:ObjectProperty ;
  rdfs:label "Forest Entity Type"@en , "Tipo de entidad forestal"@es ;
  skos:prefLabel "Forest Entity Type"@en , "Tipo de entidad forestal"@es ;
  skos:definition "The ecosystem entity type for which the phenology metric is derived. Values may identify forest entities such as coniferous or deciduous forest."@en , "Tipo de entidad ecosistémica para la que se deriva la métrica fenológica. Puede identificar entidades forestales como bosque de coníferas o bosque caducifolio."@es ;

ebv:year a owl:DatatypeProperty ;
  rdfs:label "Observation Year"@en , "Año de observación"@es ;
  skos:prefLabel "Observation Year"@en , "Año de observación"@es ;
  skos:definition "Calendar year associated with the phenology observation or derived annual EBV metric."@en , "Año natural asociado con la observación fenológica o con la métrica EBV anual derivada."@es ;
  rdfs:range xsd:integer .

ebv:vap_doy a owl:DatatypeProperty ;
  rdfs:label "Start of VAP (Day of Year)"@en , "Inicio del periodo activo de vegetación (día del año)"@es ;
  skos:prefLabel "Start of VAP (Day of Year)"@en , "Inicio del periodo activo de vegetación (día del año)"@es ;
  skos:definition "Integer day of year marking the start of the Vegetation Active Period."@en , "Día del año, expresado como entero, que marca el inicio del Periodo Activo de Vegetación."@es ;
  rdfs:range xsd:integer .

ebv:mean_doy a owl:DatatypeProperty ;
  rdfs:label "Mean DOY (spatial average)"@en , "DOY medio (promedio espacial)"@es ;
  skos:prefLabel "Mean DOY (spatial average)"@en , "DOY medio (promedio espacial)"@es ;
  skos:definition "Spatial mean day-of-year value calculated across valid grid cells or pixels for the selected feature."@en , "Valor medio espacial del día del año calculado sobre las celdas o píxeles válidos del elemento seleccionado."@es ;
  rdfs:range xsd:decimal .

ebv:min_doy a owl:DatatypeProperty ;
  rdfs:label "Minimum DOY"@en , "DOY mínimo"@es ;
  skos:prefLabel "Minimum DOY"@en , "DOY mínimo"@es ;
  skos:definition "Minimum day-of-year value observed across the valid spatial cells for the selected feature."@en , "Valor mínimo del día del año observado en las celdas espaciales válidas del elemento seleccionado."@es ;
  rdfs:range xsd:integer .

ebv:max_doy a owl:DatatypeProperty ;
  rdfs:label "Maximum DOY"@en , "DOY máximo"@es ;
  skos:prefLabel "Maximum DOY"@en , "DOY máximo"@es ;
  skos:definition "Maximum day-of-year value observed across the valid spatial cells for the selected feature."@en , "Valor máximo del día del año observado en las celdas espaciales válidas del elemento seleccionado."@es ;
  rdfs:range xsd:integer .

ebv:stddev a owl:DatatypeProperty ;
  rdfs:label "Standard Deviation of DOY"@en , "Desviación típica del DOY"@es ;
  skos:prefLabel "Standard Deviation of DOY"@en , "Desviación típica del DOY"@es ;
  skos:definition "Standard deviation of day-of-year values across valid spatial cells or pixels."@en , "Desviación típica de los valores de día del año en las celdas o píxeles espaciales válidos."@es ;
  rdfs:range xsd:decimal .

ebv:valid_percent a owl:DatatypeProperty ;
  rdfs:label "Valid Pixel Percentage"@en , "Porcentaje de píxeles válidos"@es ;
  skos:prefLabel "Valid Pixel Percentage"@en , "Porcentaje de píxeles válidos"@es ;
  skos:definition "Percentage of valid spatial cells or pixels used to compute the phenology summary metric."@en , "Porcentaje de celdas o píxeles espaciales válidos utilizados para calcular la métrica fenológica resumida."@es ;
  rdfs:range xsd:decimal .

ebv:crs a owl:DatatypeProperty ;
  rdfs:label "Coordinate Reference System"@en , "Sistema de referencia de coordenadas"@es ;
  skos:prefLabel "Coordinate Reference System"@en , "Sistema de referencia de coordenadas"@es ;
  skos:definition "Coordinate reference system used by the spatial representation of the feature or coverage-derived summary."@en , "Sistema de referencia de coordenadas utilizado por la representación espacial del elemento o por el resumen derivado de la cobertura."@es ;
  rdfs:range xsd:string ;
  skos:exactMatch <https://covjson.org/def/core#referenceSystem> .

ebv:grid_width a owl:DatatypeProperty ;
  rdfs:label "Grid Width (columns)"@en , "Anchura de la malla (columnas)"@es ;
  skos:prefLabel "Grid Width (columns)"@en , "Anchura de la malla (columnas)"@es ;
  skos:definition "Number of columns in the grid used for the coverage-derived phenology data."@en , "Número de columnas de la malla utilizada para los datos fenológicos derivados de la cobertura."@es ;
  rdfs:range xsd:integer .

ebv:grid_height a owl:DatatypeProperty ;
  rdfs:label "Grid Height (rows)"@en , "Altura de la malla (filas)"@es ;
  skos:prefLabel "Grid Height (rows)"@en , "Altura de la malla (filas)"@es ;
  skos:definition "Number of rows in the grid used for the coverage-derived phenology data."@en , "Número de filas de la malla utilizada para los datos fenológicos derivados de la cobertura."@es ;
  rdfs:range xsd:integer .

ebv:sensor a owl:DatatypeProperty ;
  rdfs:label "Source Sensor Platform"@en , "Plataforma sensora de origen"@es ;
  skos:prefLabel "Source Sensor Platform"@en , "Plataforma sensora de origen"@es ;
  skos:definition "Sensor or observation platform used as the source for the phenology derivation."@en , "Sensor o plataforma de observación utilizada como fuente para la derivación fenológica."@es ;
  rdfs:range xsd:string ;
  skos:exactMatch <http://www.w3.org/ns/prov#wasGeneratedBy> .

ebv:algorithm a owl:DatatypeProperty ;
  rdfs:label "Derivation Algorithm"@en , "Algoritmo de derivación"@es ;
  skos:prefLabel "Derivation Algorithm"@en , "Algoritmo de derivación"@es ;
  skos:definition "Algorithm or processing method used to derive the phenology metric."@en , "Algoritmo o método de procesamiento utilizado para derivar la métrica fenológica."@es ;
  rdfs:range xsd:string ;
  skos:exactMatch <http://www.w3.org/ns/prov#used> .

ebv:trend_slope a owl:DatatypeProperty ;
  rdfs:label "Trend Slope (days/year)"@en , "Pendiente de tendencia (días/año)"@es ;
  skos:prefLabel "Trend Slope (days/year)"@en , "Pendiente de tendencia (días/año)"@es ;
  skos:definition "Rate of change of the VAP start date over time, expressed in days per year."@en , "Tasa de cambio de la fecha de inicio del VAP a lo largo del tiempo, expresada en días por año."@es ;
  rdfs:range xsd:decimal .

ebv:anomaly a owl:DatatypeProperty ;
  rdfs:label "Annual Anomaly Status"@en , "Estado de anomalía anual"@es ;
  skos:prefLabel "Annual Anomaly Status"@en , "Estado de anomalía anual"@es ;
  skos:definition "Annual anomaly category relative to a baseline, for example early, normal or late."@en , "Categoría de anomalía anual respecto a una línea base, por ejemplo temprana, normal o tardía."@es ;
  rdfs:range xsd:string .

ebv:ConiferousForest a owl:Class ;
  rdfs:label "Coniferous Forest"@en , "Bosque de coníferas"@es ;
  skos:prefLabel "Coniferous Forest"@en , "Bosque de coníferas"@es ;
  skos:definition "Forest dominated by cone-bearing trees, mainly spruce and pine in the Finnish context."@en , "Bosque dominado por árboles que producen conos, principalmente abeto y pino en el contexto finlandés."@es .

ebv:DeciduousForest a owl:Class ;
  rdfs:label "Deciduous Forest"@en , "Bosque caducifolio"@es ;
  skos:prefLabel "Deciduous Forest"@en , "Bosque caducifolio"@es ;
  skos:definition "Forest dominated by broad-leaved trees that shed leaves seasonally, mainly birch in the Finnish context."@en , "Bosque dominado por árboles de hoja ancha que pierden sus hojas estacionalmente, principalmente abedul en el contexto finlandés."@es .
