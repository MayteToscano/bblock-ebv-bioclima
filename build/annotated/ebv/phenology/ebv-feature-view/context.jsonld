{
  "@context": {
    "entity_type": {
      "@context": {
        "@base": "https://w3id.org/ogc/hosted/ebv-phenology/"
      },
      "@id": "ebv:entity_type",
      "@type": "@id"
    },
    "year": {
      "@id": "ebv:year",
      "@type": "xsd:integer"
    },
    "vap_doy": {
      "@id": "ebv:vap_doy",
      "@type": "xsd:integer"
    },
    "mean_doy": {
      "@id": "ebv:mean_doy",
      "@type": "xsd:decimal"
    },
    "min_doy": {
      "@id": "ebv:min_doy",
      "@type": "xsd:integer"
    },
    "max_doy": {
      "@id": "ebv:max_doy",
      "@type": "xsd:integer"
    },
    "stddev": {
      "@id": "ebv:stddev",
      "@type": "xsd:decimal"
    },
    "valid_percent": {
      "@id": "ebv:valid_percent",
      "@type": "xsd:decimal"
    },
    "crs": "covjson:referenceSystem",
    "grid_width": {
      "@id": "ebv:grid_width",
      "@type": "xsd:integer"
    },
    "grid_height": {
      "@id": "ebv:grid_height",
      "@type": "xsd:integer"
    },
    "sensor": "prov:wasGeneratedBy",
    "algorithm": "prov:used",
    "trend_slope": {
      "@id": "ebv:trend_slope",
      "@type": "xsd:decimal"
    },
    "anomaly": "ebv:anomaly",
    "ebv": "https://w3id.org/ogc/hosted/ebv-phenology/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "covjson": "https://covjson.org/def/core#",
    "prov": "http://www.w3.org/ns/prov#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "qudt": "http://qudt.org/schema/qudt/",
    "@version": 1.1
  }
}