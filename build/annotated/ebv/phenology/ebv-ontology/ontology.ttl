@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ebv: <https://w3id.org/ogc/hosted/ebv-phenology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ebv: a owl:Ontology ;
    dcterms:title "EBV Phenology Ontology"@en,
        "Ontología Fenología EBV"@es,
        "Ontologia Fenologiei EBV"@ro,
        "EBV物候学本体"@zh .

ebv:ConiferousForest a owl:Class ;
    rdfs:label "Coniferous Forest"@en,
        "Bosque de Coníferas"@es,
        "Pădure de Conifere"@ro,
        "针叶林"@zh .

ebv:DeciduousForest a owl:Class ;
    rdfs:label "Deciduous Forest"@en,
        "Bosque Caduco"@es,
        "Pădure Caducă"@ro,
        "落叶林"@zh .

ebv:GroundObservation a owl:Class ;
    rdfs:label "Ground Observation"@en,
        "Observación Terrestre"@es,
        "Observație la Teren"@ro,
        "地面观察"@zh .

ebv:PeakGreenness a owl:Class ;
    rdfs:label "Peak Greenness"@en,
        "Máximo Verdor"@es,
        "Verdețe Maximă"@ro,
        "最大绿度"@zh ;
    rdfs:subClassOf ebv:EcosystemPhenology .

ebv:RemoteSensing a owl:Class ;
    rdfs:label "Remote Sensing"@en,
        "Teledetección"@es,
        "Teledetecție"@ro,
        "遥感"@zh .

ebv:StartOfSenescence a owl:Class ;
    rdfs:label "Start of Senescence"@en,
        "Inicio de la Senescencia"@es,
        "Începutul Senescenței"@ro,
        "衰老开始"@zh ;
    rdfs:subClassOf ebv:EcosystemPhenology .

ebv:StartOfVAP a owl:Class ;
    rdfs:label "Start of Vegetation Active Period"@en,
        "Inicio del Periodo Activo de Vegetación"@es,
        "Începutul Perioadei Active a Vegetației"@ro,
        "植被活跃期起始"@zh ;
    rdfs:subClassOf ebv:EcosystemPhenology .

ebv:entity_type a owl:ObjectProperty ;
    rdfs:label "entity type"@en,
        "tipo de entidad"@es,
        "tip de entitate"@ro,
        "实体类型"@zh .

ebv:vap_doy a owl:DatatypeProperty ;
    rdfs:label "VAP Day of Year"@en,
        "Día del Año VAP"@es,
        "Ziua Anului VAP"@ro,
        "VAP年日数"@zh .

ebv:EcosystemFunctioning a owl:Class ;
    rdfs:label "Ecosystem Functioning"@en,
        "Funcionamiento del Ecosistema"@es,
        "Funcționarea Ecosistemului"@ro,
        "生态系统功能"@zh .

ebv:EcosystemPhenology a owl:Class ;
    rdfs:label "Ecosystem Phenology"@en,
        "Fenología del Ecosistema"@es,
        "Fenologia Ecosistemului"@ro,
        "生态系统物候学"@zh ;
    rdfs:subClassOf ebv:EcosystemFunctioning .

